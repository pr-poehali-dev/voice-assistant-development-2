      },
      "expectedStatus": 200,
      "expectedBody": {
        "response": "string",
        "status": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "POST empty message",
      "method": "POST",
      "path": "/",
      "body": {
        "message": ""
